{
    "name": "blackcube/graphql",
    "description": "GraphQL read-only API for Blackcube CMS",
    "keywords": [
        "graphql",
        "api",
        "cms",
        "headless",
        "blackcube"
    ],
    "type": "library",
    "license": "BSD-3-Clause",
    "readme": "README.md",
    "homepage": "https://github.com/blackcubeio/graphql",
    "support": {
        "issues": "https://github.com/blackcubeio/graphql/issues",
        "source": "https://github.com/blackcubeio/graphql"
    },
    "authors": [
        {
            "name": "Philippe Gaultier",
            "email": "philippe@blackcube.io"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "blackcube/dcore": "^1.0",
        "webonyx/graphql-php": "^15.31",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "httpsoft/http-message": "^1.1",
        "vlucas/phpdotenv": "^5.6",
        "yiisoft/db-mysql": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Blackcube\\Graphql\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Blackcube\\Graphql\\Tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-devel": "1.x-dev"
        },
        "config-plugin-file": "config/configuration.php"
    },
    "config": {
        "sort-packages": true
    }
}
